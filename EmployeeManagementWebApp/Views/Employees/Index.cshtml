@model IEnumerable<EmployeeManagementWebApp.Models.Employee>

@{
    ViewData["Title"] = "Employee Analytics Dashboard";
    var totalEmployees = Model?.Count() ?? 0;

    // Explicitly formatting values to Indian Rupee (₹) layout format
    var avgSalary = totalEmployees > 0 ? "₹" + Model!.Average(e => e.Salary).ToString("N0") : "₹0";
    var distinctDepts = totalEmployees > 0 ? Model!.Select(e => e.Department).Distinct().Count() : 0;
}

<div class="container-fluid py-4 bg-dark text-light rounded shadow-lg min-vh-100">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
        <div>
            <h1 class="text-info fw-bold m-0">📊 Workforce Control Center</h1>
            <p class="text-muted m-0">CodTech Enterprise Systems Management</p>
        </div>
        <a asp-action="Create" class="btn btn-success btn-lg shadow">
            ➕ Add New Employee
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white border-0 shadow">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-uppercase text-white-50 m-0">Total Active Staff</h6>
                        <h2 class="display-6 fw-bold m-0">@totalEmployees</h2>
                    </div>
                    <span class="fs-1">👥</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-dark border-0 shadow">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-uppercase text-dark-50 m-0">Operating Departments</h6>
                        <h2 class="display-6 fw-bold m-0">@distinctDepts</h2>
                    </div>
                    <span class="fs-1">🏢</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark border-0 shadow">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-uppercase text-dark-50 m-0">Avg Salary Footprint</h6>
                        <h2 class="display-6 fw-bold m-0">@avgSalary</h2>
                    </div>
                    <span class="fs-1">💰</span>
                </div>
            </div>
        </div>
    </div>

    <div class="card bg-secondary text-white border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-8">
                    <input type="text" id="searchInput" class="form-control bg-dark text-white border-secondary" placeholder="Search records dynamically by Name, Email, or Designation...">
                </div>
                <div class="col-md-4">
                    <select id="deptFilter" class="form-select bg-dark text-white border-secondary">
                        <option value="">All Departments</option>
                        @if (Model != null)
                        {
                            @foreach (var dept in Model.Select(e => e.Department).Distinct())
                            {
                                <option value="@dept">@dept</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive bg-secondary rounded shadow-sm">
        <table class="table table-dark table-hover align-middle m-0" id="employeeTable">
            <thead class="table-info text-dark">
                <tr>
                    <th class="p-3">First Name</th>
                    <th>Last Name</th>
                    <th>Email Address</th>
                    <th>Department</th>
                    <th>Designation</th>
                    <th>Salary</th>
                    <th class="text-center p-3">System Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr class="employee-row" data-dept="@item.Department">
                            <td class="p-3 fw-bold text-info">@item.FirstName</td>
                            <td>@item.LastName</td>
                            <td class="text-muted">@item.Email</td>
                            <td><span class="badge bg-primary">@item.Department</span></td>
                            <td>@item.Designation</td>
                            <td class="text-warning fw-bold">₹@item.Salary.ToString("N0")</td>
                            <td class="text-center p-3">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning fw-bold text-dark">✏️ Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info fw-bold text-dark">👁️ View</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger fw-bold">🗑️ Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted fs-5">No core employee assets deployed. Click "Add New Employee" to begin records compilation.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById("searchInput");
        const deptFilter = document.getElementById("deptFilter");
        const rows = document.querySelectorAll(".employee-row");

        function filterTable() {
            const searchText = searchInput.value.toLowerCase();
            const selectedDept = deptFilter.value;

            rows.forEach(row => {
                const textMatch = row.textContent.toLowerCase().includes(searchText);
                const deptMatch = selectedDept === "" || row.getAttribute("data-dept") === selectedDept;

                if (textMatch && deptMatch) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        }

        if (searchInput && deptFilter) {
            searchInput.addEventListener("input", filterTable);
            deptFilter.addEventListener("change", filterTable);
        }
    });
</script>