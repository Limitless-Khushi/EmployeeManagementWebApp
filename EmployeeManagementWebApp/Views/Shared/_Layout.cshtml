<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodTech Management Suite</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
            body {
                background-color: #121212;
                color: #e0e0e0;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }
            .bg-gradient {
                background-size: 200% auto;
            }
    </style>
</head>
<body class="bg-dark text-light">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-black border-bottom border-secondary box-shadow mb-3 py-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand text-info fw-bold fs-4" asp-area="" asp-controller="Employees" asp-action="Index">🏢 CODTECH CORE ENTERPRISE</a>
                <button class="navbar-expand" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>
        </nav>
    </header>
    <div class="container-fluid px-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer border-top border-secondary bg-black text-muted py-3 fixed-bottom text-center mt-auto">
        <div class="container">
            &copy; 2026 - CodTech .Net Internship Execution - Developed by <strong>K Khushi Tiwari</strong>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>